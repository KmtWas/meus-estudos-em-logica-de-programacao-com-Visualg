algoritmo "MeuNome"
#// Função :Comandos de entrada
#// Autor : KmtWas
#// Data : 13/04/2026
#// Seção de Declarações -terceira aula curso em vídeo

var
Nome: Caractere

inicio
#// Seção de Comandos 
Escreva ("Digite seu nome: ")
Leia (Nome)
Escreva ("Muito prazer ", Nome)
fimalgoritmo
